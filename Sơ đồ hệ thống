  <diagram id="JV6cgNmbcvk_WHn_PtkY" name="Sơ đồ hoạt động">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1654" pageHeight="2336" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\n&#39; ===== Global style =====\nskinparam backgroundColor #FFFFFF\nskinparam defaultFontName Consolas\nskinparam defaultFontSize 13\nskinparam shadowing false\n\nskinparam activity {\n  BackgroundColor #F8F9FA\n  BorderColor #2C3E50\n  FontColor #2C3E50\n}\n\nskinparam decision {\n  BackgroundColor #FFF3CD\n  BorderColor #F0AD4E\n  FontColor #856404\n}\n\nskinparam arrow {\n  Color #2C3E50\n  Thickness 1.5\n}\n\nskinparam start {\n  BackgroundColor #2ECC71\n  BorderColor #27AE60\n}\n\nskinparam end {\n  BackgroundColor #E74C3C\n  BorderColor #C0392B\n}\n\nstart\n\n:Nhập video_path;\n:Validate video (VideoValidator);\n:Khởi tạo run_dir, CSV, EvidenceWriter;\n:Load ROI polygons (LaneConfiguration);\n:Init LaneViolationLogic state;\n\nrepeat\n  :Đọc frame kế tiếp\\n(stream từ YOLO.track);\n\n  if (Có detection / track?) then (yes)\n    :Lặp qua từng track\\n(bbox, cls, conf, track_id);\n\n    if (track_id is None?) then (skip)\n      #DDDDDD:Bỏ qua đối tượng\\n(track chưa ổn định);\n    else (ok)\n      :Gán vehicle_type từ cls;\n      :Tính current_lane = ROI(bbox);\n\n      if (current_lane == NONE) then (ignore)\n        #DDDDDD:Bỏ qua\\n(ngoài vùng xét);\n      else (in ROI)\n        :check_violation(track_id,\\nvehicle_type, current_lane);\n\n        if (violated?) then (yes)\n          #FADBD8:ViolationManager.dedup(track_id);\n\n          if (đã ghi trước đó?) then (yes)\n            #E5E7E9:Không ghi thêm record;\n          else (no)\n            #FDEDEC:Chụp ảnh (JPG);\n            #FDEDEC:Ghi CSV;\n            #FDEDEC:Enqueue DB insert;\n          endif\n\n          #F5B7B1:EvidenceWriter.write\\n(frame, slow_repeat);\n\n        else (no)\n          #D5F5E3:EvidenceWriter.write\\n(frame, normal);\n        endif\n\n      endif\n    endif\n\n  else (no)\n    #E5E7E9:Ghi frame thường;\n  endif\n\nrepeat while (còn frame?) is (yes)\n\n:Flush DB pending inserts;\n:Đóng video writer\\n+ file handles;\n\nstop\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="jM7GOVDYBj60j1NCAeQa-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1504" width="1016" x="240" y="330" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
