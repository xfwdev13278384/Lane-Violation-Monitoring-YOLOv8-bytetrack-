    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="1390" pageHeight="980" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Sequence - per-frame processing\n\nparticipant \&quot;TrackingROIDirection\&quot; as TRD\nparticipant \&quot;YOLO+ByteTrack\&quot; as YT\nparticipant \&quot;LaneConfiguration\&quot; as LC\nparticipant \&quot;GeometryUtils\&quot; as GU\nparticipant \&quot;LaneViolationLogic\&quot; as LVL\nparticipant \&quot;ViolationManager\&quot; as VM\nparticipant \&quot;VideoEvidenceWriter\&quot; as VEW\nparticipant \&quot;DBWriter\&quot; as DBW\n\nTRD -&gt; YT : results = track(stream=True)\nloop each frame\n  YT --&gt; TRD : frame + tracks\n  TRD -&gt; LC : get polygons\n  loop each track\n    TRD -&gt; GU : lane = bbox_in_roi(bbox, polygons)\n    alt lane == NONE\n      TRD -&gt; VEW : write(frame, normal)\n    else lane in ROI\n      TRD -&gt; LVL : decision(track_id, vehicle_type, lane)\n      alt violated\n        TRD -&gt; VM : handle_violation(track_id, ...)\n        VM -&gt; DBW : enqueue_insert(record)\n        TRD -&gt; VEW : write(frame, slow_repeat)\n      else not violated\n        TRD -&gt; VEW : write(frame, normal)\n      end\n    end\n  end\nend\nTRD -&gt; DBW : flush_pending_inserts()\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="ZTqrPHQknbMnf5OR7DUh-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="579" width="1216" x="87" y="201" as="geometry" />
