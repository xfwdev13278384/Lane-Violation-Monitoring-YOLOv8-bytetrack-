        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\nactor User\n\nUser -&gt; \&quot;main.py\&quot; : run(video_path)\n\&quot;main.py\&quot; -&gt; \&quot;core/video_validator.py\&quot; : validate(video_path)\n\&quot;main.py\&quot; -&gt; \&quot;core/tracking_roi_direction.py\&quot; : TrackingROIDirection.run()\n\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;Ultralytics YOLO\&quot; : model.track(stream=True)\n\&quot;Ultralytics YOLO\&quot; --&gt; \&quot;core/tracking_roi_direction.py\&quot; : per-frame Results\n\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;core/lane_configuration.py\&quot; : load polygons\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;core/geometry_utils.py\&quot; : bbox ∈ polygon?\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;core/lane_violation_logic.py\&quot; : check_violation(track_id,...)\n\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;core/violation_manager.py\&quot; : handle_violation(...)\n\&quot;core/violation_manager.py\&quot; -&gt; \&quot;core/db_writer.py\&quot; : enqueue_insert(...)\n\&quot;core/tracking_roi_direction.py\&quot; -&gt; \&quot;core/video_evidence_writer.py\&quot; : write(frame, is_violation)\n\n\&quot;core/db_writer.py\&quot; -&gt; \&quot;MySQL\&quot; : flush_pending_inserts()\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="cf8wvbs49LXzRxVNfTCT-1">
